  "views": {
    "public.hotel_capacity": {
      "columns": {
        "hotel_id": {
          "name": "hotel_id",
          "type": "integer",
          "primaryKey": false,
          "notNull": true
        },
        "hotel_address": {
          "name": "hotel_address",
          "type": "varchar(255)",
          "primaryKey": false,
          "notNull": true
        },
        "chain_name": {
          "name": "chain_name",
          "type": "varchar(100)",
          "primaryKey": false,
          "notNull": true
        },
        "star_rating": {
          "name": "star_rating",
          "type": "integer",
          "primaryKey": false,
          "notNull": true
        },
        "total_rooms": {
          "name": "total_rooms",
          "type": "integer",
          "primaryKey": false,
          "notNull": true
        },
        "single_rooms": {
          "name": "single_rooms",
          "type": "integer",
          "primaryKey": false,
          "notNull": true
        },
        "double_rooms": {
          "name": "double_rooms",
          "type": "integer",
          "primaryKey": false,
          "notNull": true
        },
        "suite_rooms": {
          "name": "suite_rooms",
          "type": "integer",
          "primaryKey": false,
          "notNull": true
        },
        "family_rooms": {
          "name": "family_rooms",
          "type": "integer",
          "primaryKey": false,
          "notNull": true
        },
        "total_guest_capacity": {
          "name": "total_guest_capacity",
          "type": "integer",
          "primaryKey": false,
          "notNull": true
        }
      },
      "definition": "\n  SELECT\n    h.hotel_id,\n    h.address AS hotel_address,\n    hc.chain_name,\n    h.star_rating,\n    COUNT(r.room_number) AS total_rooms,\n    COUNT(CASE WHEN r.capacity = 'single' THEN 1 END) AS single_rooms,\n    COUNT(CASE WHEN r.capacity = 'double' THEN 1 END) AS double_rooms,\n    COUNT(CASE WHEN r.capacity = 'suite' THEN 1 END) AS suite_rooms,\n    COUNT(CASE WHEN r.capacity = 'family' THEN 1 END) AS family_rooms,\n    SUM(CASE\n      WHEN r.capacity = 'single' THEN 1\n      WHEN r.capacity = 'double' THEN 2\n      WHEN r.capacity = 'suite' THEN 2\n      WHEN r.capacity = 'family' THEN 4\n      ELSE 0\n    END) AS total_guest_capacity\n  FROM hotel h\n  JOIN hotel_chain hc ON h.hotel_chain_central_address = hc.central_address\n  LEFT JOIN room r ON h.hotel_id = r.hotel_id\n  GROUP BY h.hotel_id, h.address, hc.chain_name, h.star_rating\n",
      "name": "hotel_capacity",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    },
    "public.rooms_per_area": {
      "columns": {
        "area": {
          "name": "area",
          "type": "varchar(255)",
          "primaryKey": false,
          "notNull": true
        },
        "available_rooms": {
          "name": "available_rooms",
          "type": "integer",
          "primaryKey": false,
          "notNull": true
        }
      },
      "definition": "\n  SELECT\n    h.address AS area,\n    COUNT(r.room_number) AS available_rooms\n  FROM hotel h\n  JOIN room r ON h.hotel_id = r.hotel_id\n  WHERE NOT EXISTS (\n    SELECT 1 FROM booking b\n    WHERE b.hotel_id = r.hotel_id\n      AND b.room_number = r.room_number\n      AND CURRENT_DATE BETWEEN b.start_date AND b.end_date\n  )\n  AND NOT EXISTS (\n    SELECT 1 FROM renting rt\n    WHERE rt.hotel_id = r.hotel_id\n      AND rt.room_number = r.room_number\n      AND CURRENT_DATE BETWEEN rt.start_date AND rt.end_date\n  )\n  GROUP BY h.address\n",
      "name": "rooms_per_area",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    }
  },
